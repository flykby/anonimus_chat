# Copy to .env on the production VM. Never commit .env.

# --- Registry ---
REGISTRY_URL=registry.internal/anonimus
REGISTRY_USER=
REGISTRY_PASSWORD=
IMAGE_TAG=latest

ENV_FILE=.env

# --- Postgres / Redis (on same VM) ---
POSTGRES_USER=anonimus
POSTGRES_PASSWORD=anonimus
POSTGRES_DB=anonimus
POSTGRES_PORT=5432
REDIS_PORT=6379

DATABASE_URL=postgresql://anonimus:anonimus@postgres:5432/anonimus
REDIS_URL=redis://redis:6379/0

# --- Bot ---
BOT_TOKEN=
LOG_LEVEL=info
# BOT listens on :8080 inside the container; prod compose does not publish it on the host.

# --- API / AI (internal docker network in prod) ---
API_PORT=8000
AI_PORT=8001

# --- RunPod (036+) ---
RUNPOD_LLM_URL=
RUNPOD_LLM_API_KEY=
RUNPOD_EMBEDDING_URL=
RUNPOD_EMBEDDING_API_KEY=
RUNPOD_REQUEST_TIMEOUT_SEC=30

# --- HTTPS reverse proxy (optional, task 009) ---
DOMAIN=bot.example.com
WEBHOOK_URL=https://bot.example.com/telegram/webhook
