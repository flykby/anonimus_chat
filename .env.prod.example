# Copy to .env on the production VM. Never commit .env.

# --- Registry ---
REGISTRY_URL=registry.internal/anonimus
REGISTRY_USER=
REGISTRY_PASSWORD=
IMAGE_TAG=latest

# Path to env file for docker compose (default: .env in repo root)
ENV_FILE=.env

# --- Bot ---
BOT_TOKEN=
LOG_LEVEL=info
BOT_HTTP_PORT=8080

# --- HTTPS reverse proxy (optional, task 009) ---
# Start with: docker compose -f docker-compose.prod.yml --profile proxy up -d
DOMAIN=bot.example.com
WEBHOOK_URL=https://bot.example.com/telegram/webhook
