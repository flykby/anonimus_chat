# Copy to .env and fill in values. Never commit .env.

# --- Bot (Go) ---
BOT_TOKEN=
LOG_LEVEL=info
HTTP_ADDR=:8080
# CI smoke tests: health endpoint only, no Telegram API
BOT_HEALTH_ONLY=

# --- Core API ---
DATABASE_URL=postgresql://anonimus:anonimus@localhost:5432/anonimus
REDIS_URL=redis://localhost:6379/0
API_HOST=0.0.0.0
API_PORT=8000

# --- AI service ---
AI_HOST=0.0.0.0
AI_PORT=8001

# --- RunPod inference (036+) ---
RUNPOD_LLM_URL=
RUNPOD_LLM_API_KEY=
RUNPOD_EMBEDDING_URL=
RUNPOD_EMBEDDING_API_KEY=
RUNPOD_REQUEST_TIMEOUT_SEC=30

# --- Deploy / webhook ---
REGISTRY_URL=registry.internal/anonimus
WEBHOOK_URL=https://example.com/telegram/webhook
WEBHOOK_SECRET=

# --- CI (003+) ---
REGISTRY_USER=
REGISTRY_PASSWORD=
