# Copy to .env and fill in values. Never commit .env.

# --- Bot (Go) ---
BOT_TOKEN=
LOG_LEVEL=info
HTTP_ADDR=:8080
BOT_HTTP_PORT=8080
API_URL=http://api:8000
REDIS_URL=redis://redis:6379/0
# CI smoke tests: health endpoint only, no Telegram API
BOT_HEALTH_ONLY=

# --- Premium / Telegram Stars (022+) ---
PREMIUM_PRICE_STARS=200
PREMIUM_DURATION_DAYS=30

# --- Postgres (005+) ---
POSTGRES_USER=anonimus
POSTGRES_PASSWORD=anonimus
POSTGRES_DB=anonimus
POSTGRES_PORT=5432

# --- Redis (005+) ---
REDIS_PORT=6379

# --- Core API ---
# Host dev (without compose): localhost. Inside compose: postgres/redis service names.
DATABASE_URL=postgresql://anonimus:anonimus@postgres:5432/anonimus?sslmode=disable
REDIS_URL=redis://redis:6379/0
API_HOST=0.0.0.0
API_PORT=8000

# --- AI service ---
AI_HOST=0.0.0.0
AI_PORT=8001

# --- RunPod inference (036+) ---
RUNPOD_LLM_URL=
RUNPOD_LLM_API_KEY=
RUNPOD_EMBEDDING_URL=
RUNPOD_EMBEDDING_API_KEY=
RUNPOD_REQUEST_TIMEOUT_SEC=30

# --- Deploy / webhook ---
REGISTRY_URL=registry.internal/anonimus
IMAGE_TAG=latest
WEBHOOK_URL=https://example.com/telegram/webhook
WEBHOOK_SECRET=

# --- CI (003+) ---
REGISTRY_USER=
REGISTRY_PASSWORD=
