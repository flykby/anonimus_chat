# Copy to .env.ci on the CI VM. Never commit .env.ci.

# Internal Docker registry (Harbor, GitLab Registry, registry:2, etc.)
REGISTRY_URL=registry.internal/anonimus
REGISTRY_USER=
REGISTRY_PASSWORD=

# Optional: real token for full Telegram e2e smoke in CI
# BOT_TOKEN=

# CI image tag override (default: git HEAD sha)
# IMAGE_TAG=

# Git branch name for :latest tagging (default: current branch)
# GIT_BRANCH=main
