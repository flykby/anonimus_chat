# Copy to docker-compose.override.yml for local dev hot-reload.
# docker-compose.override.yml is gitignored.

services:
  api:
    volumes:
      - ./api:/app/api:ro
      - ./shared:/app/shared:ro
    command: ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

  ai:
    volumes:
      - ./ai:/app/ai:ro
      - ./shared:/app/shared:ro
    command: ["uvicorn", "ai.main:app", "--host", "0.0.0.0", "--port", "8001", "--reload"]
